// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums as required by the acceptance criteria
enum UserRole {
  USER
  ADMIN
  MODERATOR
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
  SUSPENDED
}

enum DonationStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

enum MilestoneStatus {
  PENDING
  APPROVED
  RELEASED
  REJECTED
  COMPLETED
}

// All required models with relations, foreign keys, and indices

model User {
  id            String    @id @default(uuid())
  walletAddress String    @unique
  displayName   String?
  bio           String?
  avatarUrl     String?
  role          UserRole  @default(USER)
  email         String?   @unique
  kycStatus     String    @default("not_submitted")
  isSuspended   Boolean   @default(false)
  suspensionReason String?
  verifiedStatus Boolean @default(false)
  socialLinks   Json      @default("{}")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  campaigns     Campaign[]
  donations     Donation[]
  notifications Notification[]
  disputes      Dispute[]
  sentTips      PlatformTip[] @relation("TipSender")
  auditLogs     AuditLog[]
  newsletterSubscriptions Newsletter[]

  // Indices for frequently queried fields
  @@index([walletAddress])
  @@index([email])
  @@index([role])
  @@index([createdAt])
}

model Campaign {
  id           String          @id @default(uuid())
  creatorId    String
  title        String
  description  String
  goalAmount   Decimal         @db.Decimal(18, 7)
  raisedAmount Decimal         @db.Decimal(18, 7) @default(0)
  currency     String          @default("XLM")
  status       CampaignStatus  @default(DRAFT)
  category     String?
  imageUrl     String?
  endDate      DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  // Relations
  creator      User            @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  donations    Donation[]
  milestones   Milestone[]
  updates      Update[]
  disputes     Dispute[]

  // Indices for frequently queried fields
  @@index([creatorId])
  @@index([status])
  @@index([createdAt])
  @@index([endDate])
  @@index([category])
  @@index([title, description]) // Full-text search support
}

model Donation {
  id           String          @id @default(uuid())
  campaignId   String
  donorId      String?
  amount       Decimal         @db.Decimal(18, 7)
  currency     String          @default("XLM")
  status       DonationStatus  @default(PENDING)
  transactionHash String?      @unique
  message      String?
  isAnonymous  Boolean         @default(false)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  // Relations
  campaign     Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  donor        User?           @relation(fields: [donorId], references: [id], onDelete: SetNull)

  // Indices for frequently queried fields
  @@index([campaignId])
  @@index([donorId])
  @@index([status])
  @@index([createdAt])
  @@index([transactionHash])
}

model Milestone {
  id           String           @id @default(uuid())
  campaignId   String
  title        String
  description  String
  amount       Decimal          @db.Decimal(18, 7)
  status       MilestoneStatus  @default(PENDING)
  dueDate      DateTime?
  completedAt  DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  // Relations
  campaign     Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  // Indices
  @@index([campaignId])
  @@index([status])
  @@index([dueDate])
}

model Update {
  id           String    @id @default(uuid())
  campaignId   String
  title        String
  content      String
  imageUrl     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  campaign     Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  // Indices
  @@index([campaignId])
  @@index([createdAt])
}

model Notification {
  id           String    @id @default(uuid())
  userId       String
  title        String
  content      String
  type         String
  isRead       Boolean   @default(false)
  relatedEntityId String?
  createdAt    DateTime  @default(now())

  // Relations
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Indices
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@index([type])
}

model Dispute {
  id           String    @id @default(uuid())
  campaignId   String
  reporterId   String
  title        String
  description  String
  status       String    @default("OPEN") // OPEN, INVESTIGATING, RESOLVED, REJECTED
  resolution   String?
  resolvedAt   DateTime?
  resolvedById String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  campaign     Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  reporter     User      @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  resolver     User?     @relation(fields: [resolvedById], references: [id], onDelete: SetNull)

  // Indices
  @@index([campaignId])
  @@index([reporterId])
  @@index([status])
  @@index([createdAt])
}

model Newsletter {
  id           String    @id @default(uuid())
  email        String    @unique
  userId       String?
  isSubscribed Boolean   @default(true)
  subscribedAt DateTime  @default(now())
  unsubscribedAt DateTime?

  // Relations
  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Indices
  @@index([email])
  @@index([isSubscribed])
  @@index([subscribedAt])
}

model AuditLog {
  id           String    @id @default(uuid())
  userId       String?
  action       String    // e.g., "CAMPAIGN_CREATED", "USER_SUSPENDED", "MILESTONE_APPROVED"
  entityType   String    // e.g., "Campaign", "User", "Milestone"
  entityId     String?
  changes      Json?     // Stores the changes made
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime  @default(now())

  // Relations
  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Indices - critical for audit and compliance
  @@index([userId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model PlatformTip {
  id           String    @id @default(uuid())
  senderId     String
  recipientId  String
  amount       Decimal   @db.Decimal(18, 7)
  currency     String    @default("XLM")
  message      String?
  transactionHash String? @unique
  createdAt    DateTime  @default(now())

  // Relations
  sender       User      @relation("TipSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient    User      @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  // Indices
  @@index([senderId])
  @@index([recipientId])
  @@index([createdAt])
  @@index([transactionHash])
}